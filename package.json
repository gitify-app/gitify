{
  "name": "gitify",
  "version": "6.20.0",
  "private": true,
  "description": "GitHub notifications on your menu bar.",
  "keywords": [
    "electron",
    "github",
    "gitify",
    "menubar",
    "notifications",
    "taskbar",
    "tray"
  ],
  "homepage": "https://gitify.io/",
  "bugs": {
    "url": "https://github.com/gitify-app/gitify/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Setch",
    "url": "https://github.com/setchy"
  },
  "contributors": [
    {
      "name": "Emmanouil Konstantinidis",
      "url": "https://github.com/manosim"
    },
    {
      "name": "Jake 'Sid' Smith",
      "url": "https://github.com/JakeSidSmith"
    },
    {
      "name": "Adam Setch",
      "url": "https://github.com/setchy"
    },
    {
      "name": "Afonso Ramos",
      "url": "https://github.com/afonsojramos"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gitify-app/gitify.git"
  },
  "main": "build/main.js",
  "scripts": {
    "clean": "rimraf build coverage dist node_modules",
    "prepare": "husky",
    "build": "vp build",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "pnpm codegen --watch",
    "dev": "concurrently --names \"vite,codegen\" --prefix-colors \"blue,magenta\" \"vp dev\" \"pnpm codegen:watch\"",
    "devtools": "concurrently --names \"dev,devtools\" --prefix-colors \"cyan,green\" \"pnpm dev\" \"react-devtools\"",
    "start": "pnpm build && pnpm dev",
    "package:linux": "electron-builder --linux",
    "package:macos": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint --fix",
    "lint:check": "vp lint",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "test": "vp test --coverage --run",
    "test:watch": "vp test --watch --coverage",
    "test:ui": "vp test --ui"
  },
  "dependencies": {
    "electron-log": "5.4.4",
    "electron-menubar": "10.0.2",
    "electron-updater": "6.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0"
  },
  "devDependencies": {
    "@discordapp/twemoji": "16.0.1",
    "@electron/notarize": "3.1.1",
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-codegen/schema-ast": "6.0.1",
    "@graphql-codegen/typescript-operations": "6.0.4",
    "@graphql-typed-document-node/core": "3.2.0",
    "@octokit/core": "7.0.6",
    "@octokit/graphql": "9.0.3",
    "@octokit/oauth-methods": "6.0.2",
    "@octokit/openapi-types": "27.0.0",
    "@octokit/plugin-paginate-rest": "14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/request": "10.0.10",
    "@octokit/request-error": "7.1.0",
    "@octokit/types": "16.0.0",
    "@parcel/watcher": "2.5.6",
    "@primer/css": "22.3.0",
    "@primer/octicons-react": "19.28.1",
    "@primer/react": "38.29.0",
    "@swc-contrib/plugin-graphql-codegen-client-preset": "0.26.0",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/semver": "7.7.1",
    "@vitejs/plugin-react": "6.0.2",
    "clsx": "2.1.1",
    "concurrently": "10.0.3",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "final-form": "5.0.1",
    "graphql": "17.0.1",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "react-devtools": "7.0.1",
    "rimraf": "6.1.3",
    "semver": "7.8.5",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-checker": "0.14.4",
    "vite-plugin-electron": "1.1.0",
    "vite-plus": "0.2.1",
    "vitest": "4.1.9",
    "zustand": "5.0.14"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
